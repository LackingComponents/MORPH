<Window x:Class="OrthoPlanner.App.ExportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Export 3D Models" Height="380" Width="300"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FF141619" Foreground="White"
        FontFamily="Segoe UI">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Select Models to Export:" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,10" />

        <Border Grid.Row="1" Background="#FF1E2126" CornerRadius="4" Padding="5" BorderBrush="#FF303640" BorderThickness="1">
            <ItemsControl x:Name="SegmentsList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelectedForExport}" 
                                  Margin="5" Foreground="White" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Cancel" Width="80" Height="26" Margin="0,0,10,0" Click="Cancel_Click" 
                    Background="#FF303640" Foreground="White" BorderThickness="0" Cursor="Hand" />
            <Button Content="Export" Width="80" Height="26" Click="Export_Click"
                    Background="#FF007ACC" Foreground="White" BorderThickness="0" Cursor="Hand" />
        </StackPanel>
    </Grid>
</Window>
