<Window x:Class="OrthoPlanner.App.StlClassificationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Classify Dental Scans" Width="480" Height="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#FF1A1E2C" Foreground="White">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="🦷 Classify Loaded Scans" FontSize="16" FontWeight="Bold" Foreground="White"/>
            <TextBlock Text="Assign each STL file as Upper Scan, Lower Scan, or Other."
                       FontSize="11" Foreground="#AAB" Margin="0,4,0,0" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- File list -->
        <Border Grid.Row="1" Background="#12FFFFFF" CornerRadius="6" Padding="4">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="FileList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8,6" Margin="2" CornerRadius="4" Background="#10FFFFFF">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding FileName}" FontSize="12"
                                               VerticalAlignment="Center" Foreground="White" TextTrimming="CharacterEllipsis"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,0,0,0">
                                        <RadioButton Content="Upper" GroupName="{Binding GroupKey}" Tag="Upper"
                                                     IsChecked="{Binding IsUpper, Mode=TwoWay}" Foreground="#8CF" Margin="0,0,8,0"
                                                     VerticalAlignment="Center"/>
                                        <RadioButton Content="Lower" GroupName="{Binding GroupKey}" Tag="Lower"
                                                     IsChecked="{Binding IsLower, Mode=TwoWay}" Foreground="#F8A" Margin="0,0,8,0"
                                                     VerticalAlignment="Center"/>
                                        <RadioButton Content="Other" GroupName="{Binding GroupKey}" Tag="Other"
                                                     IsChecked="{Binding IsOther, Mode=TwoWay}" Foreground="#AAB"
                                                     VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Footer buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" Width="80" Padding="4,6" Click="Cancel_Click"
                    Background="#30FFFFFF" Foreground="White" BorderThickness="0" Margin="0,0,8,0"/>
            <Button x:Name="OkButton" Content="OK" Width="80" Padding="4,6" Click="Ok_Click"
                    Background="#FF1B98E0" Foreground="White" BorderThickness="0" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
