<Window x:Class="OrthoPlanner.App.LightingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lighting Configuration" Height="360" Width="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BgDarkBrush}" Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="Segoe UI"
        Style="{StaticResource MainWindowStyle}">
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="💡 3D Viewport Lighting" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,15" Foreground="{StaticResource TextPrimaryBrush}" />

        <StackPanel Grid.Row="1">
            <!-- Front Light Intensity -->
            <TextBlock Text="Front Key Light Intensity:" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
            <DockPanel Margin="0,0,0,10">
                <TextBlock Text="{Binding FrontLightIntensity}" Width="30" DockPanel.Dock="Right" TextAlignment="Right" FontSize="11" VerticalAlignment="Center" />
                <Slider Minimum="0" Maximum="255" Value="{Binding FrontLightIntensity, Mode=TwoWay}" IsSnapToTickEnabled="True" TickFrequency="1" VerticalAlignment="Center" />
            </DockPanel>

            <!-- Front Light Y Angle -->
            <TextBlock Text="Front Light Z-Angle (Up/Down):" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
            <DockPanel Margin="0,0,0,10">
                <TextBlock Text="{Binding FrontLightZ, StringFormat={}{0:F2}}" Width="30" DockPanel.Dock="Right" TextAlignment="Right" FontSize="11" VerticalAlignment="Center" />
                <Slider Minimum="-1.0" Maximum="1.0" Value="{Binding FrontLightZ, Mode=TwoWay}" TickFrequency="0.1" VerticalAlignment="Center" />
            </DockPanel>

            <!-- Bottom Light Intensity -->
            <TextBlock Text="Bottom Fill Intensity:" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
            <DockPanel Margin="0,0,0,10">
                <TextBlock Text="{Binding BottomLightIntensity}" Width="30" DockPanel.Dock="Right" TextAlignment="Right" FontSize="11" VerticalAlignment="Center" />
                <Slider Minimum="0" Maximum="255" Value="{Binding BottomLightIntensity, Mode=TwoWay}" IsSnapToTickEnabled="True" TickFrequency="1" VerticalAlignment="Center" />
            </DockPanel>

            <!-- Side Light Intensity -->
            <TextBlock Text="Left &amp; Right Fill Intensity:" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
            <DockPanel Margin="0,0,0,10">
                <TextBlock Text="{Binding LeftRightLightIntensity}" Width="30" DockPanel.Dock="Right" TextAlignment="Right" FontSize="11" VerticalAlignment="Center" />
                <Slider Minimum="0" Maximum="255" Value="{Binding LeftRightLightIntensity, Mode=TwoWay}" IsSnapToTickEnabled="True" TickFrequency="1" VerticalAlignment="Center" />
            </DockPanel>

            <!-- Back Light Intensity -->
            <TextBlock Text="Back Fill Intensity:" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
            <DockPanel Margin="0,0,0,10">
                <TextBlock Text="{Binding BackLightIntensity}" Width="30" DockPanel.Dock="Right" TextAlignment="Right" FontSize="11" VerticalAlignment="Center" />
                <Slider Minimum="0" Maximum="255" Value="{Binding BackLightIntensity, Mode=TwoWay}" IsSnapToTickEnabled="True" TickFrequency="1" VerticalAlignment="Center" />
            </DockPanel>
        </StackPanel>

        <Button Grid.Row="2" Content="Close" Width="80" Height="26" Click="Close_Click"
                Background="{StaticResource BgMediumBrush}" Foreground="{StaticResource TextPrimaryBrush}" 
                BorderThickness="0" Cursor="Hand" HorizontalAlignment="Right" Margin="0,10,0,0" />
    </Grid>
</Window>
