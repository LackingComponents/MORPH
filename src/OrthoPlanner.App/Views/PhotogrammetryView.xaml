<UserControl x:Class="OrthoPlanner.App.Views.PhotogrammetryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:OrthoPlanner.App.ViewModels.Photogrammetry"
             xmlns:conv="clr-namespace:OrthoPlanner.App.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200"
             Background="#E50C1018">

    <UserControl.Resources>
        <conv:EnumToBoolConverter x:Key="EnumToBooleanConverter" />
        <conv:InverseNullToVisibilityConverter x:Key="InverseNullToVisibilityConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left Sidebar: Thumbnail Gallery & Properties -->
        <Border Grid.Column="0" Background="{StaticResource BgMediumBrush}" 
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" Padding="12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="📷 PHOTOGRAMMETRY" Foreground="White" FontWeight="Bold" FontSize="14" Margin="0,0,0,4"/>
                        <TextBlock Text="Load photos, align, and analyze soft tissue." 
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Thumbnails List -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="8">
                    <ItemsControl ItemsSource="{Binding Photos}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#FF1E2128" CornerRadius="4" Margin="0,0,0,8" Padding="4"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <!-- Highlighting when selected -->
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <!-- Select Button (Covers the thumbnail) -->
                                        <Button Grid.Row="0" Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand"
                                                Command="{Binding DataContext.SetActivePhotoCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <Image Source="{Binding ImageSource}" Height="120" Stretch="Uniform" Margin="4"/>
                                        </Button>
                                        <!-- Actions / Info -->
                                        <DockPanel Grid.Row="1" Margin="4">
                                            <Button DockPanel.Dock="Right" Content="✕"
                                                    Background="Transparent" BorderThickness="0" Foreground="#888"
                                                    Padding="3,0" VerticalAlignment="Center" Cursor="Hand"
                                                    Command="{Binding DataContext.RemovePhotoCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}" ToolTip="Remove" />
                                            <TextBlock Text="{Binding FileName}" FontSize="10" Foreground="White" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        </DockPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- File Operations & Active Properties -->
                <StackPanel Grid.Row="2" Background="{StaticResource BgDarkBrush}" Margin="8">
                    <Button Content="+ Load Photos..." Command="{Binding LoadPhotosCommand}" Background="#FF1B98E0" Foreground="White" FontWeight="Bold" Margin="0,0,0,12"/>
                    
                    <Border Visibility="{Binding ActivePhoto, FallbackValue=Collapsed}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="0,8,0,0">
                        <!-- We data-bind to the ActivePhoto here -->
                        <Grid DataContext="{Binding ActivePhoto}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <StackPanel Grid.Row="0" Margin="0,0,0,8">
                                <Button Content="↻ Rotate 90°" Command="{Binding Rotate90Command}" Background="#FF30343D" Foreground="White" BorderBrush="{StaticResource BorderBrush}" Margin="0,0,0,12" Padding="0,4"/>
                                <TextBlock Text="CATEGORY" Style="{StaticResource PanelHeader}" FontSize="9" Margin="0,0,0,4"/>
                                <ComboBox SelectedItem="{Binding Category}" Background="{StaticResource BgMediumBrush}" Foreground="White" Margin="0,0,0,8">
                                    <ComboBoxItem Content="Uncategorized" />
                                    <ComboBoxItem Content="Frontal" />
                                    <ComboBoxItem Content="Profile" />
                                    <ComboBoxItem Content="ThreeQuarter" />
                                    <ComboBoxItem Content="Intraoral" />
                                    <ComboBoxItem Content="Occlusal" />
                                </ComboBox>
                                
                                <TextBlock Text="EXPRESSION" Style="{StaticResource PanelHeader}" FontSize="9" Margin="0,0,0,4"/>
                                <ComboBox SelectedItem="{Binding Expression}" Background="{StaticResource BgMediumBrush}" Foreground="White">
                                    <ComboBoxItem Content="Uncategorized" />
                                    <ComboBoxItem Content="Neutral" />
                                    <ComboBoxItem Content="Smile" />
                                    <ComboBoxItem Content="Dynamic" />
                                </ComboBox>
                            </StackPanel>
                            
                            <StackPanel Grid.Row="1" Margin="0,8,0,0">
                                <TextBlock Text="MEASUREMENTS" Style="{StaticResource PanelHeader}" FontSize="9" Margin="0,0,0,4"/>
                                <ItemsControl ItemsSource="{Binding Measurements}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <DockPanel Margin="0,2">
                                                <TextBlock DockPanel.Dock="Left" Text="{Binding Name}" Foreground="White" FontSize="11" />
                                                <TextBlock DockPanel.Dock="Right" Text="{Binding DistanceMm, StringFormat={}{0:F1} mm}" Foreground="{StaticResource AccentBrush}" FontSize="11" HorizontalAlignment="Right" />
                                            </DockPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Right Viewport: Main Image & Tools -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Top Toolbar -->
            <Border Grid.Row="0" Background="{StaticResource BgMediumBrush}" 
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="8,4">
                <DockPanel>
                    <!-- Close button in upper right corner -->
                    <Button DockPanel.Dock="Right" Content="✕ Close" 
                            Command="{Binding DataContext.ClosePhotogrammetryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            Background="Transparent" BorderThickness="0" Foreground="White" Padding="8,4" Cursor="Hand" />
                    
                    <StackPanel Orientation="Horizontal">
                        <StackPanel.Resources>
                            <!-- Tool Button Style -->
                            <Style TargetType="RadioButton" BasedOn="{StaticResource {x:Type ToggleButton}}">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="BorderThickness" Value="1" />
                                <Setter Property="BorderBrush" Value="Transparent" />
                                <Setter Property="Padding" Value="8,4" />
                                <Setter Property="Margin" Value="0,0,4,0" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="RadioButton">
                                            <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#FF30343D" />
                                                </Trigger>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#FF1E80B4" />
                                                    <Setter TargetName="border" Property="BorderBrush" Value="#FF1B98E0" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </StackPanel.Resources>
                        
                        <!-- Tool Options -->
                        <RadioButton Content="🖐 Pan/Zoom (None)" IsChecked="{Binding ActiveTool, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=None}" 
                                     Command="{Binding SelectToolCommand}" CommandParameter="None" GroupName="Tools"/>
                        <RadioButton Content="📏 Normalize Scale" IsChecked="{Binding ActiveTool, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Normalize}" 
                                     Command="{Binding SelectToolCommand}" CommandParameter="Normalize" GroupName="Tools"/>
                        <RadioButton Content="📐 Align Horizon" IsChecked="{Binding ActiveTool, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Horizon}" 
                                     Command="{Binding SelectToolCommand}" CommandParameter="Horizon" GroupName="Tools"/>
                        <RadioButton Content="✏️ Measure" IsChecked="{Binding ActiveTool, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Measure}" 
                                     Command="{Binding SelectToolCommand}" CommandParameter="Measure" GroupName="Tools"/>
                        
                        <Separator Width="1" Background="{StaticResource BorderBrush}" Margin="8,4"/>
                        
                        <!-- Grid Overlay Toggle -->
                        <CheckBox Content="Grid Overlay" IsChecked="{Binding ShowGridOverlay}" 
                                  Foreground="White" FontSize="12" VerticalAlignment="Center" Margin="8,0" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Interactive Viewport -->
            <Grid x:Name="ViewportGrid" Grid.Row="1" ClipToBounds="True" Background="#FF0C1018"
                  MouseWheel="Viewport_MouseWheel"
                  MouseLeftButtonDown="Viewport_MouseLeftButtonDown"
                  MouseLeftButtonUp="Viewport_MouseLeftButtonUp"
                  MouseMove="Viewport_MouseMove">
                
                <Grid x:Name="ImageContainer" DataContext="{Binding ActivePhoto}" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                    <Grid.RenderTransform>
                        <TransformGroup>
                            <RotateTransform Angle="{Binding RotationAngle}" />
                            <ScaleTransform ScaleX="{Binding Scale}" ScaleY="{Binding Scale}" />
                            <TranslateTransform X="{Binding PanX}" Y="{Binding PanY}" />
                        </TransformGroup>
                    </Grid.RenderTransform>
                    
                    <Viewbox Stretch="Uniform">
                        <Grid Width="{Binding ImageSource.PixelWidth, FallbackValue=1000}" Height="{Binding ImageSource.PixelHeight, FallbackValue=1000}">
                            <Image x:Name="MainImage" Source="{Binding ImageSource}" Stretch="Fill" SnapsToDevicePixels="True"/>
                            <Canvas x:Name="DrawingCanvas" IsHitTestVisible="False" Background="Transparent"/>
                        </Grid>
                    </Viewbox>
                </Grid>

                <!-- Screen-space Grid Overlay (drawn dynamically in code behind based on PixelsPerMm and current scale) -->
                <Canvas x:Name="GridOverlayCanvas" IsHitTestVisible="False" Visibility="{Binding ShowGridOverlay, Converter={StaticResource BoolToVisibility}}" />
                
                <!-- Screen-space Active Tool Interaction Overlay -->
                <Canvas x:Name="InteractionCanvas" IsHitTestVisible="False" />
                
                <TextBlock Text="No photo selected." Foreground="#FF404552" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="{Binding ActivePhoto, Converter={StaticResource InverseNullToVisibilityConverter}}"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
